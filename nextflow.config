//
// nextflow.config — EPI2ME Labs 相容格式
//
// EPI2ME Labs 桌面 App 會讀取此檔的 manifest 與 nextflow_schema.json
// 來產生工作流的執行畫面 (UI)。
//

params {
    help            = false
    version         = false

    // --- Input Options ---
    input_file_path = null      // 必填: 輸入 CSV (mRNA, miRNAs)

    // --- Analysis Options ---
    count_threshold = 10        // 保留 count <= threshold 的 miRNA

    // --- Output Options ---
    out_dir         = "output"  // EPI2ME 慣例輸出目錄

    // --- Notification (optional) ---
    email           = null

    // 每次執行的唯一 ID (記錄於 params_used.yaml)
    job_id          = new Date().format('yyyyMMdd_HHmmss') + '_' + UUID.randomUUID().toString().take(8)

    monochrome_logs = false
    validate_params = true

    // EPI2ME 內部設定 (demo 指令等)
    wf {
        example_cmd = [
            "--input_file_path 'test_data/input.csv'",
            "--count_threshold 10",
        ]
    }
}

manifest {
    name            = 'godkin1211/CLI_python2nextflow'
    author          = 'godkin1211'
    homePage        = 'https://github.com/godkin1211/CLI_python2nextflow'
    description     = 'Reverse-aggregate an mRNA->miRNA mapping table and filter by target count.'
    mainScript      = 'main.nf'
    defaultBranch   = 'main'
    nextflowVersion = '>=23.04.0'
    version         = 'v1.0.0'
}

// EPI2ME Labs 專屬: 在桌面 App 中的標籤分類
epi2melabs {
    tags = 'mirna,mrna,csv,aggregation,utility'
}

profiles {
    // "standard" 為 Nextflow 預設 profile (本機直接用系統 python3)
    standard {
        process.executor = 'local'
    }

    // 容器化執行 (可重現性更佳)
    docker {
        docker.enabled    = true
        process.container = 'python:3.11-slim'
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.container   = 'python:3.11-slim'
    }

    // 保留 conda stub 避免 unknown profile 警告
    conda {
        conda.enabled = true
    }

    // 簡化的本機開發 profile
    local {
        process.executor = 'local'
    }
}

// 執行報告 (EPI2ME 慣例放在 out_dir/execution/)
timeline { enabled = true; overwrite = true; file = "${params.out_dir}/execution/timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.out_dir}/execution/report.html"   }
trace    { enabled = true; overwrite = true; file = "${params.out_dir}/execution/trace.txt"      }

env {
    PYTHONNOUSERSITE = 1
}
