nextflow_pipeline {

    name "Full pipeline (reproduces reference answer)"
    script "main.nf"

    test("run on real input.csv with count_threshold=10") {
        when {
            params {
                input_file_path = "${projectDir}/test_data/input.csv"
                count_threshold = 10
                out_dir         = "$outputDir"
            }
        }
        then {
            assert workflow.success

            // 對齊參考答案 test_data/expected/
            def output_csv   = path("$outputDir/output/output.csv")
            def filtered_csv = path("$outputDir/output/filtered_output.csv")

            assert output_csv.readLines().size()   == 261   // header + 260 miRNA
            assert filtered_csv.readLines().size() == 121   // header + 120 (count<=10)

            // 「使用之參數」快照應被產出
            assert path("$outputDir/params_used.yaml").exists()
            assert path("$outputDir/params_used.yaml").text.contains("count_threshold: 10")

            // EPI2ME HTML 報告應被產出且自包含 (無外部連結)
            def report = path("$outputDir/report.html")
            assert report.exists()
            assert report.text.contains("miRNAs (total)")
            assert !report.text.contains("http://") && !report.text.contains("https://")
        }
    }

    test("invalid count_threshold=0 is rejected by parameter validation") {
        when {
            params {
                input_file_path = "${projectDir}/test_data/input.csv"
                count_threshold = 0          // 違反 count_threshold >= 1
                out_dir         = "$outputDir"
            }
        }
        then {
            // 手動驗證應在任何 process 執行前就讓 pipeline 失敗 (fail fast)
            assert workflow.failed
            assert workflow.exitStatus != 0
            // 失敗原因應是參數驗證 (而非其他執行錯誤)
            assert (workflow.errorReport ?: "").contains("Validation of pipeline parameters failed") ||
                   workflow.stdout.any { it.contains("Validation of pipeline parameters failed") }
        }
    }
}
