/*
 * Gmail 郵件通知設定 (可選, 用 -c 引入, 不影響主流程)
 *
 * 使用前置作業:
 *   1. 在 Google 帳號開啟「兩步驟驗證」(2-Step Verification)
 *   2. 產生「應用程式密碼」(App Password, 16 碼) —— 不是你的登入密碼
 *   3. 把 App Password 存成 Nextflow secret (不要寫進檔案):
 *        nextflow secrets set GMAIL_APP_PASSWORD "xxxx xxxx xxxx xxxx"
 *   4. 設定寄件帳號 (環境變數):
 *        export GMAIL_USER="your@gmail.com"
 *
 * 執行 (--email 指定收件人):
 *   nextflow run main.nf -params-file config.yaml \
 *       -c conf/email.config --email your@gmail.com
 */

params {
    email = "n28994055@gs.ncku.edu.tw"      // 收件人; null = 不寄信
}

// (26.04 strict config: 頂層不可用 def 變數，故下方兩處直接內插寄件帳號)
// 寄件帳號: 有設環境變數 GMAIL_USER 就用它，否則用預設 (任何 session 都能跑)

// Gmail SMTP 連線設定
mail {
    smtp {
        host     = 'smtp.gmail.com'
        port     = 587
        user     = System.getenv('GMAIL_USER') ?: 'n28111021@gs.ncku.edu.tw'
        password = secrets.GMAIL_APP_PASSWORD     // 從 nextflow secrets 讀取
        auth     = true
        starttls {
            enable   = true
            required = true
        }
        // Java 17+ 搭配內建 JavaMail 在 STARTTLS 需明確指定 TLS 版本，
        // 否則會出現 "Could not convert socket to TLS"
        ssl.protocols = 'TLSv1.2'
    }
}

// 內建通知: pipeline 結束 (成功/失敗皆會) 自動寄出含執行摘要的 HTML 信
notification {
    enabled = params.email as boolean
    to      = params.email
    from    = System.getenv('GMAIL_USER') ?: 'n28111021@gs.ncku.edu.tw'
}
