# ===== Nextflow 執行產物 =====
.nextflow/
.nextflow.log*
work/

# ===== 工作流輸出 (EPI2ME out_dir, 每次執行自動生成) =====
output/
results/

# ===== nf-test 執行暫存 (但保留 *.snap 基準與 tests/) =====
.nf-test/
.nf-test.log

# ===== Python 快取 =====
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ===== 憑證 / 機密 (千萬不要進版控) =====
# App Password 應存在 ~/.nextflow/secrets/,不在專案內;
# 以下為保險,避免不小心把含密碼的檔案加入
*.secret
.env
secrets.*

# ===== macOS / 編輯器 =====
.DS_Store
*.swp
.idea/
.vscode/
