nextflow_process {

    name "FILTER_BY_COUNT"
    script "modules/local/filter_by_count.nf"
    process "FILTER_BY_COUNT"

    test("keep only rows with count <= threshold") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file("${projectDir}/tests/data/mini_aggregated.csv")
                input[1] = 2
                """
            }
        }
        then {
            assert process.success
            def out = path(process.out.filtered[0])
            def lines = out.readLines()

            // header + mir-2(count=2) + mir-3(count=1)
            assert lines.size() == 3
            assert out.text.contains('mir-2,2')
            assert out.text.contains('mir-3,1')

            // 關鍵: count=3 的 mir-1 應被濾掉 (保留 count <= threshold)
            assert !out.text.contains('mir-1,3')

            assert snapshot(process.out).match()
        }
    }
}
