/*
 * nextflow.config —— 預設參數、profiles、執行報告
 * 執行時的實際值由 -params-file config.yaml 覆寫。
 */

// 啟用 nf-schema plugin —— 提供 validateParameters() / paramsSummaryLog() 等
plugins {
    id 'nf-schema@2.6.1'
}

params {
    input_file_path = null      // 必填 (由 -params-file 提供)
    count_threshold = 10        // 預設門檻

    // Job ID: 每次執行產生唯一值 (對應原本 Python 的 uuid4().hex[:8])
    // 格式: <時間戳>_<8碼亂數>，可排序又唯一
    job_id          = new Date().format('yyyyMMdd_HHmmss') + '_' + UUID.randomUUID().toString().take(8)
    // 該次 job 的輸出根目錄 (對應原本的 jobs/<job_id>/)；可用 --outdir 覆寫
    // (26.04 strict: 需用 params.job_id 明確引用,不能裸寫 job_id)
    outdir          = 'jobs/' + params.job_id

    email           = null      // 收件信箱; null = 不寄通知信 (搭配 -c conf/email.config)
}

// (可選) 控制驗證行為，不必動到 schema 本身
validation {
    monochromeLogs = false
    help { enabled = true }     // 啟用 --help 自動依 schema 產生說明
}

profiles {
    // 預設: 直接用本機系統的 python3 (無需 Docker)
    standard {
        process.executor = 'local'
    }
    // 容器化執行 (可重現性更佳): nextflow run ... -profile docker
    docker {
        docker.enabled    = true
        process.container = 'python:3.11-slim'
    }
    singularity {
        singularity.enabled = true
        process.container   = 'python:3.11-slim'
    }
}

// 執行報告 —— 連同 params_used.yaml 一起構成完整的「使用之參數 / 資源」紀錄
// (Nextflow 26.04 strict config: 不可在頂層用 def 變數，改為直接內插 params.outdir)
timeline { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_report.html"   }
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_info/execution_trace.txt"      }

manifest {
    name            = 'mirna-reverse-aggregate'
    description     = 'Reverse-aggregate mRNA->miRNA mapping and filter by count threshold'
    version         = '1.0.0'
    nextflowVersion = '>=23.04.0'
}
