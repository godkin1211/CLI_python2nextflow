{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/mirna-reverse-aggregate/main/nextflow_schema.json",
    "title": "mirna-reverse-aggregate pipeline parameters",
    "description": "Reverse-aggregate mRNA->miRNA mapping and filter by count threshold",
    "type": "object",
    "$defs": {
        "input_output_options": {
            "title": "Input/output options",
            "type": "object",
            "required": ["input_file_path"],
            "properties": {
                "input_file_path": {
                    "type": "string",
                    "format": "file-path",
                    "pattern": "^\\S+\\.csv$",
                    "description": "輸入 CSV (欄位: mRNA, miRNAs)，miRNAs 為逗號分隔。"
                },
                "outdir": {
                    "type": "string",
                    "format": "directory-path",
                    "description": "輸出目錄。預設為 jobs/<job_id>/。"
                },
                "job_id": {
                    "type": "string",
                    "description": "本次執行的唯一 Job ID (預設自動產生: <時間戳>_<亂數>)。",
                    "hidden": true
                }
            }
        },
        "analysis_options": {
            "title": "Analysis options",
            "type": "object",
            "properties": {
                "count_threshold": {
                    "type": "integer",
                    "default": 10,
                    "minimum": 1,
                    "description": "保留 count <= threshold 的 miRNA (對應 mRNA 數量越少越專一)。"
                }
            }
        },
        "notification_options": {
            "title": "Notification options",
            "type": "object",
            "properties": {
                "email": {
                    "type": "string",
                    "format": "email",
                    "description": "收件信箱; 設定後 pipeline 結束會寄送通知信 (需搭配 -c conf/email.config)。"
                }
            }
        }
    },
    "allOf": [
        { "$ref": "#/$defs/input_output_options" },
        { "$ref": "#/$defs/analysis_options" },
        { "$ref": "#/$defs/notification_options" }
    ]
}
